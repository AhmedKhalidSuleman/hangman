<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hangman.controller.MenuController"
      fx:id="rootVBox"
      alignment="CENTER"
      spacing="18"
      styleClass="root-pane"
      stylesheets="@../css/style.css">

    <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

    <Label fx:id="titleLabel"
           text="🎯 HANGMAN"
           styleClass="title-label"/>

    <Label text="Il Gioco dell'Impiccato"
           styleClass="subtitle-label"/>

    <Label fx:id="streakLabel"
           text="🏆 Best streak: 0"
           styleClass="streak-label"/>

    <Separator/>

    <VBox alignment="CENTER" spacing="10">
        <Label text="⚡ DIFFICOLTÀ" styleClass="section-label"/>
        <HBox alignment="CENTER" spacing="20">
            <fx:define>
                <ToggleGroup fx:id="difficultyGroup"/>
            </fx:define>

            <RadioButton fx:id="rbEasy"   text="😊 Facile (8 errori)"   selected="true"
                         toggleGroup="$difficultyGroup" styleClass="radio-option"/>
            <RadioButton fx:id="rbMedium" text="😐 Medio (6 errori)"
                         toggleGroup="$difficultyGroup" styleClass="radio-option"/>
            <RadioButton fx:id="rbHard"   text="😈 Difficile (4 errori)"
                         toggleGroup="$difficultyGroup" styleClass="radio-option"/>
        </HBox>
    </VBox>

    <Separator/>

    <VBox alignment="CENTER" spacing="10">
        <Label text="🎮 MODALITÀ DI GIOCO" styleClass="section-label"/>
        <HBox alignment="CENTER" spacing="30">
            <fx:define>
                <ToggleGroup fx:id="modeGroup"/>
            </fx:define>

            <RadioButton fx:id="rbSingle" text="👤 Giocatore Singolo" selected="true"
                         toggleGroup="$modeGroup" styleClass="radio-option"/>
            <RadioButton fx:id="rbMulti"  text="👥 Due Giocatori"
                         toggleGroup="$modeGroup" styleClass="radio-option"/>
        </HBox>
    </VBox>

    <GridPane alignment="CENTER" hgap="15" vgap="8">
        <Label text="Nome Giocatore 1:" GridPane.columnIndex="0" GridPane.rowIndex="0"
               styleClass="field-label"/>
        <TextField fx:id="player1NameField" promptText="Inserisci nome..."
                   GridPane.columnIndex="1" GridPane.rowIndex="0"
                   styleClass="name-field" prefWidth="200"/>

        <Label fx:id="player2NameLabel" text="Nome Giocatore 2:"
               GridPane.columnIndex="0" GridPane.rowIndex="1"
               styleClass="field-label"/>
        <TextField fx:id="player2NameField" promptText="Inserisci nome..."
                   GridPane.columnIndex="1" GridPane.rowIndex="1"
                   styleClass="name-field" prefWidth="200"/>
    </GridPane>

    <Separator/>

    <HBox alignment="CENTER" spacing="20">
        <Button fx:id="btnPlay" text="▶  GIOCA" onAction="#onPlay"
                styleClass="btn-primary" prefWidth="160" prefHeight="50"/>
        <Button fx:id="btnLeaderboard" text="🏆  CLASSIFICA" onAction="#onLeaderboard"
                styleClass="btn-secondary" prefWidth="160" prefHeight="50"/>
    </HBox>

    <Label text="Usa la tastiera o i pulsanti sullo schermo per giocare"
           styleClass="footer-label"/>

</VBox>