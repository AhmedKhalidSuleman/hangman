<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hangman.controller.LeaderboardController"
      alignment="CENTER"
      spacing="16"
      styleClass="root-pane"
      stylesheets="@../css/style.css">

    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>

    <Label text="🏆 CLASSIFICA" styleClass="title-label"/>
    <Label text="Top 20 punteggi salvati" styleClass="subtitle-label"/>

    <Separator/>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName"       text="Giocatore"   prefWidth="160"/>
            <TableColumn fx:id="colScore"      text="Punteggio"   prefWidth="100"/>
            <TableColumn fx:id="colDifficulty" text="Difficoltà"  prefWidth="110"/>
            <TableColumn fx:id="colStreak"     text="Streak"      prefWidth="80"/>
            <TableColumn fx:id="colDate"       text="Data"        prefWidth="140"/>
        </columns>
        <placeholder><Label text="Nessun punteggio ancora. Gioca una partita!"/></placeholder>
    </TableView>

    <HBox alignment="CENTER" spacing="20">
        <Button text="← Torna al Menu" onAction="#onBack"
                styleClass="btn-secondary" prefWidth="180" prefHeight="42"/>
        <Button fx:id="btnClear" text="🗑 Cancella tutto" onAction="#onClearScores"
                styleClass="btn-danger" prefWidth="180" prefHeight="42"/>
    </HBox>

</VBox>
