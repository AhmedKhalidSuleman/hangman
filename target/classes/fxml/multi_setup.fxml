<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.hangman.controller.MultiSetupController"
      alignment="CENTER"
      spacing="24"
      styleClass="root-pane"
      stylesheets="@../css/style.css">

    <padding><Insets top="60" right="80" bottom="60" left="80"/></padding>

    <Label text="👥 MODALITÀ DUE GIOCATORI"
           styleClass="title-label"/>

    <Label fx:id="instructionLabel"
           text="Istruzioni..."
           styleClass="info-label"
           wrapText="true"
           textAlignment="CENTER"
           maxWidth="600"/>

    <Separator/>

    <Label fx:id="playerLabel"
           text="Giocatore 1 — inserisci la parola segreta:"
           styleClass="section-label"/>

    <PasswordField fx:id="wordField"
                   promptText="Digita la parola segreta (nascosta)..."
                   styleClass="name-field"
                   prefWidth="400"
                   prefHeight="45"/>

    <Label fx:id="errorLabel"
           text=""
           styleClass="error-label"/>

    <HBox alignment="CENTER" spacing="20">
        <Button text="✅  AVVIA PARTITA" onAction="#onStart"
                styleClass="btn-primary" prefWidth="200" prefHeight="48"/>
        <Button text="← Indietro" onAction="#onBack"
                styleClass="btn-secondary" prefWidth="140" prefHeight="48"/>
    </HBox>

    <Label text="Il campo è nascosto — solo tu puoi vedere cosa scrivi!"
           styleClass="footer-label"/>

</VBox>
